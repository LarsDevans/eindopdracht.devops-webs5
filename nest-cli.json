{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/read-service/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/read-service/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/read-service",
  "projects": {
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "main",
      "sourceRoot": "apps/api-gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api-gateway/tsconfig.app.json"
      }
    },
    "auth": {
      "type": "library",
      "root": "libs/auth",
      "entryFile": "index",
      "sourceRoot": "libs/auth/src",
      "compilerOptions": {
        "tsConfigPath": "libs/auth/tsconfig.lib.json"
      }
    },
    "clock-service": {
      "type": "application",
      "root": "apps/clock-service",
      "entryFile": "main",
      "sourceRoot": "apps/clock-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/clock-service/tsconfig.app.json"
      }
    },
    "imgbb": {
      "type": "library",
      "root": "libs/imgbb",
      "entryFile": "index",
      "sourceRoot": "libs/imgbb/src",
      "compilerOptions": {
        "tsConfigPath": "libs/imgbb/tsconfig.lib.json"
      }
    },
    "kafka": {
      "type": "library",
      "root": "libs/kafka",
      "entryFile": "index",
      "sourceRoot": "libs/kafka/src",
      "compilerOptions": {
        "tsConfigPath": "libs/kafka/tsconfig.lib.json"
      }
    },
    "mail-service": {
      "type": "application",
      "root": "apps/mail-service",
      "entryFile": "main",
      "sourceRoot": "apps/mail-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/mail-service/tsconfig.app.json"
      }
    },
    "prometheus": {
      "type": "library",
      "root": "libs/prometheus",
      "entryFile": "index",
      "sourceRoot": "libs/prometheus/src",
      "compilerOptions": {
        "tsConfigPath": "libs/prometheus/tsconfig.lib.json"
      }
    },
    "read-service": {
      "type": "application",
      "root": "apps/read-service",
      "entryFile": "main",
      "sourceRoot": "apps/read-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/read-service/tsconfig.app.json"
      }
    },
    "score-service": {
      "type": "application",
      "root": "apps/score-service",
      "entryFile": "main",
      "sourceRoot": "apps/score-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/score-service/tsconfig.app.json"
      }
    },
    "submission-service": {
      "type": "application",
      "root": "apps/submission-service",
      "entryFile": "main",
      "sourceRoot": "apps/submission-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/submission-service/tsconfig.app.json"
      }
    },
    "target-service": {
      "type": "application",
      "root": "apps/target-service",
      "entryFile": "main",
      "sourceRoot": "apps/target-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/target-service/tsconfig.app.json"
      }
    },
    "types": {
      "type": "library",
      "root": "libs/types",
      "entryFile": "index",
      "sourceRoot": "libs/types/src",
      "compilerOptions": {
        "tsConfigPath": "libs/types/tsconfig.lib.json"
      }
    }
  }
}